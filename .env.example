# ─────────────────────────────────────────────────────────────────────────────
# Root .env — consumed by docker-compose only.
# Copy to .env and fill in your values before running `docker compose up`.
#
# Server-specific variables (JWT_SECRET, RAZORPAY_*, CLIENT_URL, etc.) live in
# server/.env  (see server/.env.example).
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
# REQUIRED — use a strong random password in production:
#   openssl rand -base64 32
POSTGRES_PASSWORD=changeme_strong_password

# ── Port mapping overrides (optional) ────────────────────────────────────────
# Change these if the defaults conflict with other local services.
POSTGRES_PORT=5432
API_PORT=3001
APP_PORT=80

# ─── Environment variables ────────────────────────────────────────────────────
# Never commit real secrets. Each sub-project also has its own .gitignore.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
server/.env
server/.env.local
client/.env
client/.env.local
# Allow example files to be committed (they must contain only placeholders)
!**/.env.example

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
server/node_modules/
client/node_modules/

# ─── Build output ─────────────────────────────────────────────────────────────
client/dist/
client/dist-ssr/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Test artifacts ───────────────────────────────────────────────────────────
server/coverage/
client/coverage/
client/playwright-report/
client/test-results/
client/blob-report/
playwright/.cache/

# ─── Prisma ───────────────────────────────────────────────────────────────────
server/prisma/migrations/*/migration.sql

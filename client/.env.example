# =============================================================================
# B2B Marketplace Frontend — Production template (Vercel)
# =============================================================================
# Set in Vercel → Project → Settings → Environment Variables.
# Variables must be prefixed with VITE_ to be embedded at build time.
# Rebuild/redeploy after changing any VITE_* value.
# =============================================================================

# ─── Required for Vercel + separate Render API host ─────────────────────────

# Full URL to the Render backend API (must end with /api).
# On Vercel: Name = VITE_API_BASE_URL  |  Value = https://git-repo-az5t.onrender.com/api
# Do NOT put "VITE_API_BASE_URL=" inside the Value field — only the https://... URL.
VITE_API_BASE_URL=https://git-repo-az5t.onrender.com/api

# ─── Optional ─────────────────────────────────────────────────────────────────

# Legacy alias for VITE_API_BASE_URL (do not set both unless they match)
# VITE_API_URL="https://your-render-service.onrender.com/api"

# HTTP request timeout in ms (default: 30000)
# VITE_API_TIMEOUT=30000

# UI display name (default: B2B Marketplace)
# VITE_APP_NAME="B2B Marketplace"

# Razorpay public key_id — fallback if API omits keyId; must match server RAZORPAY_KEY_ID
# Never put RAZORPAY_KEY_SECRET here.
# VITE_RAZORPAY_KEY_ID="rzp_live_REPLACE_ME"

# ─── Local development only (Vite dev server proxy — not used on Vercel) ────
# VITE_BACKEND_URL="http://localhost:3001"

# ─── PostgreSQL (Neon) ────────────────────────────────────────────────────────
# Copy your connection string from the Neon dashboard (Connection details).
# Use the *pooled* host (-pooler) for the running API; sslmode=require is required.
#
# Example (replace user, password, host, and database name):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
#
# Optional: set DIRECT_URL to the non-pooler host for `prisma migrate deploy` if migrations fail via pooler.
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
#
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# REQUIRED in production. Comma-separated list of allowed frontend origins.
# Must use https:// in production. Must not contain localhost or 127.0.0.1.
# In development this variable is optional — localhost:5173 and localhost:3000
# are allowed automatically when NODE_ENV=development.
# CLIENT_URL=https://your-app.yourdomain.com

# ─── Seed (Docker entrypoint only) ───────────────────────────────────────────
# Set to "true" on first boot to load demo users, products and orders.
# Switch back to "false" (or remove) before going live.
SEED_DB=false

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Get your keys from https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_* keys for development/testing, rzp_live_* for production.
RAZORPAY_KEY_ID="rzp_test_REPLACE_ME"
RAZORPAY_KEY_SECRET="REPLACE_ME_TEST_SECRET"

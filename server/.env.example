# =============================================================================
# B2B Marketplace API — Production environment template
# =============================================================================
# Copy to .env for local development, or set each variable in Render → Environment.
# Never commit real secrets. Never commit .env to git.
# =============================================================================

# ─── Required (app will not start in production without these) ───────────────

# PostgreSQL connection string (Neon recommended).
# Use the *pooled* host (-pooler) for the running API. sslmode=require is required.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# JWT signing secret — min 32 random bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Allowed browser origins for CORS + cookies (comma-separated, no trailing slash).
# REQUIRED when NODE_ENV=production. Must match the browser Origin exactly.
#
# Primary production frontend:
CLIENT_URL="https://git-repo-gilt.vercel.app"
#
# Optional extra origins / Vercel preview deployments (supports wildcards):
# CORS_ALLOWED_ORIGINS="https://git-repo-gilt.vercel.app,https://git-repo-*.vercel.app"
#
# Optional override for Access-Control-Allow-Headers (comma-separated).
# Default includes Content-Type, Authorization, Accept, Cache-Control, X-Requested-With.
# CORS_ALLOWED_HEADERS="Content-Type,Authorization,Accept,Cache-Control,X-Requested-With"

# Must be "production" on Render.
NODE_ENV="production"

# ─── Required for payments (app starts without them; subscriptions return 503) ─

# Razorpay — https://dashboard.razorpay.com → Settings → API Keys
# Production: use rzp_live_* keys. Test keys (rzp_test_*) only log warnings in production.
RAZORPAY_KEY_ID="rzp_live_REPLACE_ME"
RAZORPAY_KEY_SECRET="REPLACE_ME_LIVE_SECRET"

# ─── Optional (sensible defaults exist) ───────────────────────────────────────

# Render sets PORT automatically; default 3001 if unset.
PORT=3001

# JWT lifetime for auth cookies (also drives cookie maxAge). Default: 7d
# Formats: 7d, 24h, 3600s
JWT_EXPIRES_IN="7d"

# ─── Render / Docker build & release (not read by env.js at runtime) ─────────

# Run once after deploy (Render build command or manual shell):
#   npx prisma generate
#   npx prisma migrate deploy
#   node src/db/migrate.js
# Optional first-time data:
#   node prisma/seed.js
#   node src/db/migrate.js --seed

# Docker entrypoint only — do not set on Render unless using docker-entrypoint.sh
# SEED_DB=false

# Prisma optional — add to schema.prisma if migrate deploy fails via pooler:
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

{
  "name": "b2b-ecommerce-api",
  "version": "1.0.0",
  "private": true,
  "description": "B2B ecommerce REST API (Express + PostgreSQL + Prisma)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:seed:prod": "NODE_ENV=production node prisma/seed.js",
    "db:studio": "prisma studio",
    "catalog:migrate": "node src/db/migrate.js",
    "catalog:seed": "node src/db/migrate.js --seed",
    "render:build": "prisma generate && prisma db push && node src/db/migrate.js",
    "free:port": "powershell -NoProfile -Command \"$p=$env:PORT; if(!$p){$p=3001}; Get-NetTCPConnection -LocalPort $p -State Listen -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }; Write-Host ('Port ' + $p + ' freed')\""
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^6.3.0",
    "razorpay": "^2.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2"
  }
}
